#!/bin/bash
# ================================================================
#   NETGETK VPN Script - Instalador Principal
#   GitHub: https://github.com/NETGETK/NETGETK-Script
#   By: NETGETK
# ================================================================

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; WHITE='\033[1;37m'; NC='\033[0m'; BOLD='\033[1m'

REPO="https://raw.githubusercontent.com/NETGETK/NETGETK-Script/main"
INSTALL_DIR="/etc/netgetk"
LICENSE_SERVER="http://102.129.137.143:3000"   # Tu servidor de licencias
VERSION="1.0"

clear
echo -e "${CYAN}"
cat << 'LOGO'
  _   _ _____ _____ ____  _____ _____ _  __
 | \ | | ____|_   _/ ___|| ____|_   _| |/ /
 |  \| |  _|   | || |  _ |  _|   | | | ' /
 | |\  | |___  | || |_| || |___  | | | . \
 |_| \_|_____| |_| \____||_____| |_| |_|\_\
LOGO
echo -e "${WHITE}     VPN SCRIPT v${VERSION} | Ubuntu 20/22 LTS${NC}"
echo -e "${CYAN}================================================================${NC}"
echo ""

# ── Verificar root ─────────────────────────────────────────────
[[ $EUID -ne 0 ]] && echo -e "${RED}[!] Ejecutar como root${NC}" && exit 1

# ── Verificar Ubuntu ───────────────────────────────────────────
source /etc/os-release 2>/dev/null
if [[ "$ID" != "ubuntu" ]]; then
    echo -e "${RED}[!] Solo Ubuntu 20.04 / 22.04${NC}"; exit 1
fi

# ── Obtener IP del VPS ─────────────────────────────────────────
VPS_IP=$(curl -s --max-time 5 ifconfig.me 2>/dev/null || \
         curl -s --max-time 5 ip.sb 2>/dev/null || \
         hostname -I | awk '{print $1}')

echo -e " ${WHITE}IP detectada:${NC} ${CYAN}$VPS_IP${NC}"
echo ""

# ── Verificar si ya está instalado ────────────────────────────
if [[ -f "$INSTALL_DIR/config.conf" ]] && [[ "$1" != "update" ]]; then
    source "$INSTALL_DIR/config.conf" 2>/dev/null
    if [[ -n "$LICENSE_KEY" ]]; then
        echo -e "${YELLOW}[!] Script ya instalado. Abriendo menú...${NC}"
        sleep 1; exec /usr/local/bin/menu
        exit 0
    fi
fi

# ── Solicitar KEY de licencia ──────────────────────────────────
echo -e "${WHITE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${YELLOW}  Este script requiere una licencia válida.${NC}"
echo -e "${YELLOW}  Contacta: @NETGETK en Telegram para obtener tu KEY.${NC}"
echo -e "${WHITE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo -ne " ${WHITE}Ingresa tu LICENSE KEY: ${NC}"
read LICENSE_KEY

if [[ -z "$LICENSE_KEY" ]]; then
    echo -e "${RED}[!] KEY requerida${NC}"; exit 1
fi

# ── Validar licencia contra el servidor ───────────────────────
echo ""
echo -e "${CYAN}[*] Validando licencia...${NC}"

VALIDATE_RESP=$(curl -s --max-time 10 \
    -X POST "$LICENSE_SERVER/api/validate" \
    -H "Content-Type: application/json" \
    -d "{\"key\":\"$LICENSE_KEY\",\"ip\":\"$VPS_IP\",\"action\":\"install\"}" 2>/dev/null)

STATUS=$(echo "$VALIDATE_RESP" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('status','error'))" 2>/dev/null)
MSG=$(echo "$VALIDATE_RESP"    | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('message','Error de conexión'))" 2>/dev/null)
OWNER=$(echo "$VALIDATE_RESP"  | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('owner',''))" 2>/dev/null)
EXPIRY=$(echo "$VALIDATE_RESP" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('expiry',''))" 2>/dev/null)

if [[ "$STATUS" != "ok" ]]; then
    echo ""
    echo -e "${RED}╔══════════════════════════════════════╗${NC}"
    echo -e "${RED}║     ✗ LICENCIA INVÁLIDA               ║${NC}"
    echo -e "${RED}╠══════════════════════════════════════╣${NC}"
    echo -e "${RED}║${NC} Motivo: ${YELLOW}$MSG${NC}"
    echo -e "${RED}╚══════════════════════════════════════╝${NC}"
    echo ""
    echo -e " Contacta ${CYAN}@NETGETK${NC} en Telegram para soporte."
    exit 1
fi

echo ""
echo -e "${GREEN}╔══════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║         ✓ LICENCIA VÁLIDA                  ║${NC}"
echo -e "${GREEN}╠══════════════════════════════════════════╣${NC}"
echo -e "${GREEN}║${NC} ${WHITE}Usuario :${NC} ${CYAN}$OWNER${NC}"
echo -e "${GREEN}║${NC} ${WHITE}Expira  :${NC} ${YELLOW}$EXPIRY${NC}"
echo -e "${GREEN}║${NC} ${WHITE}IP VPS  :${NC} ${CYAN}$VPS_IP${NC}"
echo -e "${GREEN}╚══════════════════════════════════════════╝${NC}"
echo ""
sleep 2

# ── Instalar dependencias ──────────────────────────────────────
echo -e "${CYAN}[1/5] Actualizando sistema...${NC}"
apt update -y -qq 2>/dev/null
apt upgrade -y -qq 2>/dev/null

echo -e "${CYAN}[2/5] Instalando dependencias...${NC}"
apt install -y -qq curl wget git unzip net-tools lsof python3 python3-pip \
    openssh-server nginx fail2ban ufw jq bc screen cron vnstat htop openssl \
    uuid-runtime 2>/dev/null

# Node.js 18
if ! command -v node &>/dev/null; then
    echo -e "${CYAN}  → Instalando Node.js...${NC}"
    curl -fsSL https://deb.nodesource.com/setup_18.x | bash - 2>/dev/null
    apt install -y nodejs 2>/dev/null
fi

# PM2
command -v pm2 &>/dev/null || npm install -g pm2 -q 2>/dev/null

# ── Instalar Xray ──────────────────────────────────────────────
echo -e "${CYAN}[3/5] Instalando Xray...${NC}"
bash -c "$(curl -L https://github.com/XTLS/Xray-install/raw/main/install-release.sh)" @ install -u root 2>/dev/null
mkdir -p /var/log/xray
[[ -f /usr/local/bin/xray ]] && \
    echo -e "${GREEN}  ✓ Xray $(/usr/local/bin/xray version 2>/dev/null | grep -oP 'Xray \K[\d.]+'  )${NC}"

# ── Descargar archivos del script ─────────────────────────────
echo -e "${CYAN}[4/5] Descargando archivos...${NC}"
mkdir -p "$INSTALL_DIR/Server" "$INSTALL_DIR/back" "$INSTALL_DIR/users" \
         "$INSTALL_DIR/panel/public" /var/log/netgetk

for f in manager banner.sh Server/ssh.sh Server/xray.sh Server/ssl.sh \
          Server/socks5.sh Server/slowdns.sh Server/udp.sh \
          back/usuarios.sh back/contador.sh back/optimizador.sh \
          back/firewall.sh back/speedtest.sh \
          panel/server.js panel/package.json panel/public/index.html; do
    wget -q -O "$INSTALL_DIR/$f" "$REPO/$f" 2>/dev/null
    chmod +x "$INSTALL_DIR/$f" 2>/dev/null
done

# ── Configuración inicial ──────────────────────────────────────
echo -e "${CYAN}[5/5] Configurando sistema...${NC}"

# Guardar configuración
cat > "$INSTALL_DIR/config.conf" << CONF
LICENSE_KEY=$LICENSE_KEY
LICENSE_OWNER=$OWNER
LICENSE_EXPIRY=$EXPIRY
VPS_IP=$VPS_IP
INSTALL_DATE=$(date +%Y-%m-%d)
SCRIPT_VERSION=$VERSION
SSH_PORT=22
CONF

# Comando global menu
ln -sf "$INSTALL_DIR/manager" /usr/local/bin/menu
chmod +x /usr/local/bin/menu

# SSH optimización básica
sed -i 's/#MaxAuthTries.*/MaxAuthTries 3/' /etc/ssh/sshd_config 2>/dev/null
echo "AllowTcpForwarding yes" >> /etc/ssh/sshd_config 2>/dev/null
systemctl restart ssh 2>/dev/null

# UFW básico
ufw --force reset 2>/dev/null
ufw default deny incoming 2>/dev/null
ufw default allow outgoing 2>/dev/null
ufw allow 22/tcp 2>/dev/null
ufw allow 80/tcp 2>/dev/null
ufw --force enable 2>/dev/null

# Instalar panel web
cd "$INSTALL_DIR/panel"
npm install --silent 2>/dev/null
pm2 delete netgetk-panel 2>/dev/null
pm2 start server.js --name netgetk-panel 2>/dev/null
pm2 startup 2>/dev/null
pm2 save 2>/dev/null
ufw allow 2095/tcp 2>/dev/null

# Cron: verificar licencia diariamente
(crontab -l 2>/dev/null | grep -v netgetk-license; \
 echo "0 6 * * * curl -s -X POST $LICENSE_SERVER/api/heartbeat -H 'Content-Type: application/json' -d '{\"key\":\"$LICENSE_KEY\",\"ip\":\"$VPS_IP\"}' > /dev/null 2>&1") | crontab -

echo ""
echo -e "${GREEN}╔════════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║    ✓ NETGETK SCRIPT INSTALADO CORRECTAMENTE     ║${NC}"
echo -e "${GREEN}╠════════════════════════════════════════════════╣${NC}"
echo -e "${GREEN}║${NC} ${WHITE}Panel Web:${NC} ${CYAN}http://$VPS_IP:2095${NC}"
echo -e "${GREEN}║${NC} ${WHITE}Usuario:${NC}   ${CYAN}admin${NC}  ${WHITE}Pass:${NC} ${CYAN}admin123${NC}"
echo -e "${GREEN}║${NC}"
echo -e "${GREEN}║${NC} ${WHITE}Comando:${NC}   ${CYAN}menu${NC}  (para abrir el manager)"
echo -e "${GREEN}╚════════════════════════════════════════════════╝${NC}"
echo ""
sleep 2
exec /usr/local/bin/menu
