#!/bin/bash
# ============================================================
#   NETGETK VPN Script - Setup Principal
#   By: NETGETK | github.com/getakgt1/NETGETK-Script
#   Ubuntu 20.04 / 22.04 / 24.04
# ============================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

# --- Validar Licencia ---
LICENSE_SERVER="http://102.129.137.143:4000"
VPS_IP=$(curl -s ifconfig.me)
echo -e "${CYAN}[*] Ingresa tu KEY de licencia:${NC}"
read -p "► KEY: " LICENSE_KEY
if [[ -z "$LICENSE_KEY" ]]; then
    echo -e "${RED}[!] KEY requerida${NC}"; exit 1
fi
echo -e "${CYAN}[*] Validando licencia...${NC}"
RESPONSE=$(curl -s -X POST "$LICENSE_SERVER/api/validate" \
    -H "Content-Type: application/json" \
    -d "{\"key\":\"$LICENSE_KEY\",\"ip\":\"$VPS_IP\",\"action\":\"install\"}")
STATUS=$(echo $RESPONSE | grep -o '"status":"[^"]*"' | cut -d'"' -f4)
MESSAGE=$(echo $RESPONSE | grep -o '"message":"[^"]*"' | cut -d'"' -f4)
OWNER=$(echo $RESPONSE | grep -o '"owner":"[^"]*"' | cut -d'"' -f4)
if [[ "$STATUS" != "ok" ]]; then
    echo -e "${RED}[!] Licencia inválida: $MESSAGE${NC}"; exit 1
fi
echo -e "${GREEN}[✓] Licencia válida - Propietario: $OWNER${NC}"
# --- Verificar root ---
if [[ $EUID -ne 0 ]]; then
   echo -e "${RED}[!] Este script debe ejecutarse como root${NC}"
   exit 1
fi
fi

# --- Verificar Ubuntu ---
source /etc/os-release 2>/dev/null
if [[ "$ID" != "ubuntu" && "$ID" != "debian" ]]; then
    echo -e "${YELLOW}[!] Recomendado: Ubuntu 20.04 / 22.04 / 24.04${NC}"
fi

clear
echo -e "${CYAN}"
cat << "EOF"
  _   _ _____ _____ ____  _____ _____ _  __
 | \ | | ____|_   _/ ___|| ____|_   _| |/ /
 |  \| |  _|   | || |  _ |  _|   | | | ' /
 | |\  | |___  | || |_| || |___  | | | . \
 |_| \_|_____| |_| \____||_____| |_| |_|\_\
EOF
echo -e "${WHITE}        NETGETK VPN SCRIPT INSTALLER${NC}"
echo -e "${YELLOW}        $(lsb_release -ds 2>/dev/null || echo "Linux") | $(uname -m)${NC}"
echo ""

echo -e "${GREEN}[*] Iniciando instalación...${NC}"
sleep 1

# --- Actualizar sistema ---
echo -e "${CYAN}[1/7] Actualizando sistema...${NC}"
apt update -y -qq 2>/dev/null
apt upgrade -y -qq 2>/dev/null

# --- Instalar dependencias base ---
echo -e "${CYAN}[2/7] Instalando dependencias...${NC}"
apt install -y -qq \
    curl wget git unzip zip \
    net-tools lsof \
    python3 python3-pip \
    openssh-server \
    nginx \
    fail2ban \
    ufw \
    jq \
    bc \
    screen \
    cron \
    vnstat \
    htop \
    openssl \
    uuid-runtime \
    dropbear 2>/dev/null
echo -e "${GREEN}  ✓ Dependencias instaladas${NC}"

# --- Instalar Node.js si no existe ---
echo -e "${CYAN}[3/7] Verificando Node.js...${NC}"
if ! command -v node &>/dev/null; then
    curl -fsSL https://deb.nodesource.com/setup_18.x | bash - 2>/dev/null
    apt install -y nodejs 2>/dev/null
fi
echo -e "${GREEN}  ✓ Node.js $(node -v 2>/dev/null)${NC}"

# Instalar PM2
if ! command -v pm2 &>/dev/null; then
    npm install -g pm2 -q 2>/dev/null
fi
echo -e "${GREEN}  ✓ PM2 instalado${NC}"

# --- Instalar Xray ---
echo -e "${CYAN}[4/7] Instalando Xray...${NC}"
bash -c "$(curl -L https://github.com/XTLS/Xray-install/raw/main/install-release.sh)" @ install -u root 2>/dev/null
if [[ -f /usr/local/bin/xray ]]; then
    echo -e "${GREEN}  ✓ Xray instalado${NC}"
else
    echo -e "${YELLOW}  ⚠ Xray: instalar manualmente desde el menú${NC}"
fi

# --- Descargar archivos del script ---
echo -e "${CYAN}[5/7] Descargando archivos del script...${NC}"
REPO="https://raw.githubusercontent.com/getakgt1/NETGETK-Script/master/script"
INSTALL_DIR="/etc/gtkvpn"

mkdir -p $INSTALL_DIR/Server
mkdir -p $INSTALL_DIR/back
mkdir -p $INSTALL_DIR/users
mkdir -p $INSTALL_DIR/panel/public
mkdir -p /var/log/gtkvpn

# Descargar scripts
SCRIPTS=(
    "manager"
    "banner.sh"
    "Server/ssh.sh"
    "Server/xray.sh"
    "Server/ssl.sh"
    "Server/socks5.sh"
    "Server/slowdns.sh"
    "Server/udp.sh"
    "back/usuarios.sh"
    "back/contador.sh"
    "back/optimizador.sh"
    "back/firewall.sh"
    "back/speedtest.sh"
)

for script in "${SCRIPTS[@]}"; do
    dest="$INSTALL_DIR/$script"
    mkdir -p "$(dirname $dest)"
    if wget -q --timeout=15 -O "${dest}.tmp" "$REPO/$script" 2>/dev/null && [[ -s "${dest}.tmp" ]]; then
        mv "${dest}.tmp" "$dest"
        chmod +x "$dest"
        echo -e "  ${GREEN}✓${NC} $(basename $script)"
    else
        rm -f "${dest}.tmp"
        echo -e "  ${YELLOW}⚠${NC} $(basename $script) (fallo, verificar GitHub)"
    fi
done

# Descargar panel web
PANEL_REPO="https://raw.githubusercontent.com/getakgt1/NETGETK-Script/master/panel"
for pfile in "server.js" "public/index.html"; do
    dest="$INSTALL_DIR/panel/$pfile"
    mkdir -p "$(dirname $dest)"
    wget -q --timeout=15 -O "$dest" "$PANEL_REPO/$pfile" 2>/dev/null || true
done

# --- Configuración inicial ---
echo -e "${CYAN}[6/7] Configurando sistema...${NC}"

VPS_IP=$(curl -s --max-time 5 ifconfig.me 2>/dev/null || curl -s --max-time 5 ip.sb 2>/dev/null || hostname -I | awk '{print $1}')

# Guardar config
cat > $INSTALL_DIR/config.conf << CONF
INSTALL_DATE=$(date +%Y-%m-%d)
SCRIPT_VERSION=$(lsb_release -ds 2>/dev/null)
VPS_IP=$VPS_IP
SSH_PORT=22
XRAY_PORT=32595
XRAY_WS_PATH=/
UDPGW_PORT=7300
SSH_WS_PORT=80
PANEL_PORT=2095
SSH_DB_PORT=2222
UDP_PORT=36712
SOCKS_PORT=8080
SOCKS_ENABLED=false
CONF

# Optimización SSH
sed -i 's/#MaxAuthTries.*/MaxAuthTries 5/' /etc/ssh/sshd_config 2>/dev/null
sed -i 's/#ClientAliveInterval.*/ClientAliveInterval 60/' /etc/ssh/sshd_config 2>/dev/null
sed -i 's/#ClientAliveCountMax.*/ClientAliveCountMax 3/' /etc/ssh/sshd_config 2>/dev/null
grep -q "AllowTcpForwarding yes" /etc/ssh/sshd_config 2>/dev/null || echo "AllowTcpForwarding yes" >> /etc/ssh/sshd_config
systemctl restart ssh 2>/dev/null
# Fix Dropbear: agregar /bin/false a shells validos
grep -qx "/bin/false" /etc/shells || echo "/bin/false" >> /etc/shells
# Fix Dropbear: agregar /bin/false a shells validos
grep -qx "/bin/false" /etc/shells || echo "/bin/false" >> /etc/shells

# Configurar Dropbear en puerto 2222
sed -i "s/NO_START=.*/NO_START=0/" /etc/default/dropbear
sed -i "s/DROPBEAR_PORT=.*/DROPBEAR_PORT=2222/" /etc/default/dropbear
systemctl restart dropbear

# Instalar proxy HTTP→SSH (puerto 80)
cat > /usr/local/bin/ssh-ws.py << 'PYEOF'
#!/usr/bin/env python3
import socket, threading, select

LISTEN_HOST = "0.0.0.0"
LISTEN_PORT = 80
SSH_HOST = "127.0.0.1"
SSH_PORT = 2222
BUFFER = 4096
RESPONSE = b"HTTP/1.1 200 OK\r\nContent-Length: 0\r\nConnection: keep-alive\r\n\r\n"

def tunnel(src, dst):
    while True:
        try:
            r, _, _ = select.select([src, dst], [], [], 60)
            if not r: break
            for s in r:
                data = s.recv(BUFFER)
                if not data: return
                (dst if s is src else src).sendall(data)
        except: break
    src.close(); dst.close()

def handle(client):
    try:
        client.recv(BUFFER)
        client.sendall(RESPONSE)
        ssh = socket.create_connection((SSH_HOST, SSH_PORT), timeout=10)
        ssh.setblocking(True)
        threading.Thread(target=tunnel, args=(client, ssh), daemon=True).start()
    except Exception as e:
        print(f"Error: {e}")
        client.close()

server = socket.socket()
server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
server.bind((LISTEN_HOST, LISTEN_PORT))
server.listen(200)
print(f"Proxy HTTP->SSH corriendo en :{LISTEN_PORT}")
while True:
    try:
        client, _ = server.accept()
        client.settimeout(30)
        threading.Thread(target=handle, args=(client,), daemon=True).start()
    except: pass
PYEOF
chmod +x /usr/local/bin/ssh-ws.py

# Crear servicio ssh-ws
cat > /etc/systemd/system/ssh-ws.service << 'SVC'
[Unit]
Description=SSH WebSocket Proxy - GTKVPN
After=network.target
[Service]
Type=simple
ExecStart=/usr/bin/python3 /usr/local/bin/ssh-ws.py
Restart=always
RestartSec=5
[Install]
WantedBy=multi-user.target
SVC
systemctl daemon-reload
systemctl enable ssh-ws
systemctl restart ssh-ws
systemctl stop nginx
systemctl disable nginx

# Instalar y configurar fail2ban
apt install fail2ban -y -q 2>/dev/null
cat > /etc/fail2ban/jail.local << 'EOF'
[sshd]
enabled = true
port = 22,2222
filter = sshd
logpath = /var/log/auth.log
maxretry = 10
bantime = 3600
findtime = 600

[dropbear]
enabled = true
port = 2222
filter = sshd
logpath = /var/log/auth.log
maxretry = 10
bantime = 3600
findtime = 600
EOF
systemctl enable fail2ban
systemctl restart fail2ban

# UFW básico
ufw --force reset 2>/dev/null
ufw default deny incoming 2>/dev/null
ufw default allow outgoing 2>/dev/null
ufw allow 22/tcp 2>/dev/null
ufw allow 80/tcp 2>/dev/null
ufw allow 443/tcp 2>/dev/null
ufw allow 2095/tcp 2>/dev/null
ufw allow 32595/tcp 2>/dev/null
ufw allow 8080/tcp 2>/dev/null
ufw allow 2222/tcp 2>/dev/null
ufw allow 7300/udp 2>/dev/null
ufw --force enable 2>/dev/null

# Instalar panel web
echo -e "${CYAN}[7/7] Instalando panel web...${NC}"
if [[ -f "$INSTALL_DIR/panel/server.js" ]]; then
    cd "$INSTALL_DIR/panel"
    npm install express express-session cors bcryptjs jsonwebtoken uuid --save -q 2>/dev/null
    pm2 delete netgetk-panel 2>/dev/null
    pm2 start server.js --name netgetk-panel 2>/dev/null
    pm2 save 2>/dev/null
    pm2 startup 2>/dev/null | tail -1 | bash 2>/dev/null
    echo -e "${GREEN}  ✓ Panel web activo en :2095${NC}"
fi

# Crear enlace global 'menu'
ln -sf $INSTALL_DIR/manager /usr/local/bin/menu
chmod +x /usr/local/bin/menu

# Cron: limpiar usuarios expirados cada hora
(crontab -l 2>/dev/null | grep -v "usuarios.sh clean"; echo "0 * * * * $INSTALL_DIR/back/usuarios.sh clean auto") | crontab -

# Habilitar cron
systemctl enable cron 2>/dev/null
systemctl start cron 2>/dev/null

echo ""
echo -e "${GREEN}╔══════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║   NETGETK SCRIPT INSTALADO CORRECTAMENTE  ║${NC}"
echo -e "${GREEN}╠══════════════════════════════════════════╣${NC}"
echo -e "${GREEN}║${NC} ${WHITE}IP VPS   :${NC} ${CYAN}$VPS_IP${NC}"
echo -e "${GREEN}║${NC} ${WHITE}Panel    :${NC} ${CYAN}http://$VPS_IP:2095${NC}"
echo -e "${GREEN}║${NC} ${WHITE}Usuario  :${NC} ${CYAN}admin / admin123${NC}"
echo -e "${GREEN}╠══════════════════════════════════════════╣${NC}"
echo -e "${GREEN}║${NC} ${YELLOW}Ejecuta ${WHITE}menu${YELLOW} para abrir el panel de control${NC}"
echo -e "${GREEN}╚══════════════════════════════════════════╝${NC}"
echo ""

sleep 2
exec $INSTALL_DIR/manager
